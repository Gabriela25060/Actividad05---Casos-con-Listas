conecta(X, Y, Costo) :-
    nodo(X, ListaViajes),
    member(viaje(Y, Costo), ListaViajes).

arista(X) :- 
    conecta(X, _, _).

costo(X, Y, Z, C) :- 
    conecta(X, Y, C1), 
    conecta(Y, Z, C2), 
    C is C1 + C2.

ruta(X, Y) :- 
    conecta(X, Y, _).

ruta(X, Y) :- 
    conecta(X, Z, _), 
    ruta(Z, Y).
